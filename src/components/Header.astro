---

<header class="site-header">
  <div class="header-inner">

    <a href="/" class="logo-link">
      <img src="/logo-500.png" alt="SONDA" class="logo-img" />
      <span class="logo-text">SONDA</span>
    </a>

    <div class="header-controls">

      <div class="cluster-switcher" role="group" aria-label="Select cluster">
        <button class="cluster-btn active" data-cluster="mainnet-beta">mainnet</button>
        <button class="cluster-btn disabled" data-cluster="testnet" title="Coming soon">testnet</button>
        <button class="cluster-btn disabled" data-cluster="devnet" title="Coming soon">devnet</button>
      </div>

<button class="theme-toggle" id="theme-toggle" aria-label="Toggle theme" title="Toggle light/dark theme">
  <span class="toggle-track">
    <span class="toggle-thumb" id="toggle-thumb"></span>
  </span>
</button>

      <a href="https://github.com/SolyaUk/sonda-network" target="_blank" rel="noopener" class="github-link" aria-label="GitHub">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
