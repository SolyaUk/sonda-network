        </svg>
      </a>

    </div>
  </div>
</header>

<style>
.site-header {
  position: sticky;
  top: 0;
  z-index: 100;
  background-color: var(--bg-primary);
  border-bottom: 1px solid var(--border);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
}

.header-inner {
  max-width: 1280px;
  margin: 0 auto;
  padding: 0 1.5rem;
  height: 60px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 1rem;
}

.logo-link {
  display: flex;
  align-items: center;
  gap: 0.6rem;
  text-decoration: none;
  color: var(--text-primary);
  flex-shrink: 0;
}

.logo-img {
  width: 36px;
  height: 36px;
  border-radius: 8px;
}

.logo-text {
  font-family: var(--font-display);
  font-size: 1.15rem;
  font-weight: 700;
  letter-spacing: 0.06em;
  color: var(--text-primary);
}

.header-controls {
  display: flex;
  align-items: center;
  gap: 0.75rem;
}

.cluster-switcher {
  display: flex;
  align-items: center;
  gap: 2px;
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: 8px;
  padding: 3px;
}

.cluster-btn {
  font-family: var(--font-mono);
  font-size: 0.7rem;
  font-weight: 500;
  padding: 0.25rem 0.6rem;
  border-radius: 5px;
  border: none;
  cursor: pointer;
  transition: all 0.15s ease;
  background: transparent;
  color: var(--text-muted);
  white-space: nowrap;
}

.cluster-btn.active {
  background: var(--accent-blue);
  color: #fff;
  cursor: default;
}

.cluster-btn.disabled {
  cursor: not-allowed;
  opacity: 0.35;
}

/* Theme toggle - pill switch */
.theme-toggle {
  background: none;
  border: none;
  cursor: pointer;
  padding: 2px;
  display: flex;
  align-items: center;
}

.toggle-track {
  position: relative;
  width: 44px;
  height: 24px;
  border-radius: 12px;
  border: 1.5px solid var(--border);
  background: var(--bg-secondary);
  display: block;
  transition: border-color 0.2s ease, background 0.2s ease;
}

.theme-toggle:hover .toggle-track {
  border-color: var(--accent-blue);
}

.toggle-thumb {
  position: absolute;
  width: 18px;
  height: 18px;
  border-radius: 50%;
  top: 2px;
  transition: left 0.2s ease, background 0.2s ease;
  background: var(--accent-blue);
}

.toggle-icon {
  position: absolute;
  font-size: 0.6rem;
  font-weight: 700;
  top: 50%;
  transform: translateY(-50%);
  color: #fff;
  line-height: 1;
  pointer-events: none;
}

.toggle-icon.moon { right: 5px; }
.toggle-icon.sun  { left: 5px; }

:global([data-theme="dark"])  .toggle-icon.sun  { opacity: 0; }
:global([data-theme="dark"])  .toggle-icon.moon { opacity: 1; }
:global([data-theme="light"]) .toggle-icon.moon { opacity: 0; }
:global([data-theme="light"]) .toggle-icon.sun  { opacity: 1; }

.toggle-thumb { left: 2px; }

.toggle-track::before {
  content: ')';
  position: absolute;
  right: 6px;
  top: 50%;
  transform: translateY(-50%);
  font-size: 0.65rem;
  color: var(--text-muted);
  pointer-events: none;
  z-index: 1;
}

.toggle-track::after {
  content: '*';
  position: absolute;
  left: 6px;
  top: 50%;
  transform: translateY(-50%);
  font-size: 0.65rem;
  color: var(--text-muted);
  pointer-events: none;
  z-index: 1;
}

.github-link {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 36px;
  height: 36px;
  border-radius: 8px;
  border: 1px solid var(--border);
  background: var(--bg-card);
  color: var(--text-secondary);
  text-decoration: none;
  transition: all 0.15s ease;
  flex-shrink: 0;
}

.github-link:hover {
  border-color: var(--accent-blue);
  color: var(--accent-blue);
}

@media (max-width: 480px) {
  .logo-text { display: none; }
  .cluster-btn { padding: 0.25rem 0.4rem; font-size: 0.65rem; }
  .header-inner { padding: 0 1rem; }
}
</style>

<script>
  function applyToggleState() {
    const theme = document.documentElement.getAttribute('data-theme') || 'dark';
    const thumb = document.getElementById('toggle-thumb');
    const track = thumb?.parentElement;
    if (!thumb) return;
    if (theme === 'light') {
      thumb.style.left = '22px';
      thumb.style.background = '#2563eb';
      if (track) track.style.background = '#e0e7ff';
    } else {
      thumb.style.left = '2px';
      thumb.style.background = '#3b82f6';
      if (track) track.style.background = '';
    }
  }

  applyToggleState();

  const toggle = document.getElementById('theme-toggle');
  toggle?.addEventListener('click', () => {
    const html = document.documentElement;
    const next = html.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
    html.setAttribute('data-theme', next);
    localStorage.setItem('sonda-theme', next);
    applyToggleState();
  });
</script>