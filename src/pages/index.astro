---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';

import fs from 'node:fs';
import path from 'node:path';

let snap = null;
try {
  const raw = fs.readFileSync(path.resolve('./public/data/snapshot.json'), 'utf8');
  snap = JSON.parse(raw);
} catch (e) {
  snap = null;
}
const v = snap?.validators;
const dec = v?.decentralization;
const dz = snap?.doublezero;
const bam = snap?.bam;
const health = snap?.cluster_health;

const fmt = (n: number) => n?.toLocaleString('en-US') ?? '-';
const pct = (n: number, digits = 1) => n != null ? `${n.toFixed(digits)}%` : '-';

function nakRating(dim: string, val: number) {
  if (dim === 'validator') {
    if (val >= 50) return 'Excellent';
    if (val >= 20) return 'Good';
    return 'Warning';
  }
  if (val <= 2) return 'Critical';
  if (val <= 5) return 'Warning';
  if (val <= 10) return 'Moderate';
  return 'Good';
}

function nakColor(rating: string) {
  if (rating === 'Excellent' || rating === 'Good') return 'good';
  if (rating === 'Warning' || rating === 'Moderate') return 'warning';
  return 'critical';
}

function hhiRating(val: number) {
  if (val > 2500) return { label: 'Highly concentrated', color: 'critical' };
  if (val > 1500) return { label: 'Moderately concentrated', color: 'warning' };
  return { label: 'Competitive', color: 'good' };
}

function giniRating(val: number) {
  if (val > 0.8) return { label: 'Very high inequality', color: 'critical' };
  if (val > 0.6) return { label: 'High inequality', color: 'warning' };
  if (val > 0.4) return { label: 'Moderate inequality', color: 'neutral' };
  return { label: 'Low inequality', color: 'good' };
}

// Country code to flag emoji
function flag(cc: string): string {
  return cc.toUpperCase().split('').map(c =>
    String.fromCodePoint(c.charCodeAt(0) + 127397)
  ).join('');
}

const topCountries = v?.country_distribution
  ? Object.entries(v.country_distribution as Record<string, number>).slice(0, 10)
  : [];
const maxCount = topCountries[0]?.[1] ?? 1;

const stakeByVersion = health?.stake_by_version
  ? Object.entries(health.stake_by_version as Record<string, any>)
      .filter(([k]) => k !== 'unknown')
      .sort((a, b) => b[1].currentActiveStake - a[1].currentActiveStake)
      .slice(0, 3)
  : [];

const updatedAt = snap?.timestamp
  ? new Date(snap.timestamp).toUTCString().replace('GMT', 'UTC')
  : '-';

const skipRate = health?.average_stake_weighted_skip_rate ?? 0;
const delinqPct = health?.delinquent_stake_percent ?? 0;

const hhi_country = dec?.hhi_country?.value;
const hhi_asn = dec?.hhi_asn?.value;
const gini = dec?.gini_validators?.value;
---

<BaseLayout>
  <Header />

  <!-- Dev banner - visible everywhere -->
<div class="dev-banner">
  <div class="dev-banner-inner">
    <span class="dev-badge">BETA</span>
    Dashboard is under active development. Data may come from older snapshots. Some sections are incomplete.
    <a href="https://github.com/SolyaUk/sonda-network" target="_blank" rel="noopener" class="dev-link">View on GitHub</a>
  </div>
</div>

  <main class="main-content">
    <div class="container">

      <!-- HERO -->
      <section class="hero">
        <div class="hero-label">Solana Observatory for Network Decentralization Analysis</div>
        <h1 class="hero-title">The Solana network,<br/>mapped and verified.</h1>
        <p class="hero-desc">
          Multi-source geo-verified analysis of validator distribution,
          infrastructure coverage, and network health.
        </p>
        <div class="hero-meta">
          <span class="epoch-badge">
            Epoch <span class="mono">{snap?.epoch ?? '-'}</span>
            <span class="epoch-dot"></span>
            <span class="mono">{snap?.epoch_completed_percent ?? '-'}%</span> complete
          </span>
          <span class="updated-badge">
            Snapshot: <span class="mono">{updatedAt}</span>
          </span>
        </div>
      </section>

      <!-- NETWORK HEALTH -->
      <section class="section">
        <h2 class="section-title">Network Health</h2>
        <p class="section-desc">Current state of the validator set and cluster performance.</p>

        <div class="cards-grid cards-4">

          <div class="card">
            <div class="card-label">Active Validators</div>
            <div class="card-value violet">{fmt(v?.total)}</div>
            <div class="card-sub">of {fmt(v?.total_all)} total, {v?.offline} offline</div>
          </div>

          <div class="card">
            <div class="card-label">
              Delinquent Stake
              <span class="tooltip-wrap">
                <span class="tooltip-icon">?</span>
                <span class="tooltip-box">Percentage of total stake held by validators that are behind on voting. Below 1% is healthy.</span>
              </span>
            </div>
            <div class={`card-value ${delinqPct > 1 ? 'warning' : delinqPct > 5 ? 'critical' : 'good'}`}>
              {pct(delinqPct, 2)}
            </div>
            <div class="card-sub">of total active stake</div>
          </div>

          <div class="card">
            <div class="card-label">
              Skip Rate
              <span class="tooltip-wrap">
                <span class="tooltip-icon">?</span>
                <span class="tooltip-box">Stake-weighted average percentage of assigned leader slots that were skipped. Lower is better. A healthy network stays below 1%.</span>
              </span>
            </div>
            <div class={`card-value ${skipRate > 1 ? 'warning' : 'good'}`}>
              {pct(skipRate, 2)}
            </div>
            <div class="card-sub">stake-weighted</div>
          </div>

          <div class="card">
            <div class="card-label">RPC Nodes</div>
            <div class="card-value violet">{fmt(snap?.record_counts?.rpc)}</div>
            <div class="card-sub">public RPC endpoints</div>
          </div>

        </div>

        {stakeByVersion.length > 0 && (
          <div class="version-bar-wrap">
            <div class="card-label">Top Client Versions</div>
            <div class="version-list">
              {stakeByVersion.map(([ver, info]) => (
                <div class="version-item">
                  <span class="version-name mono">{ver}</span>
                  <span class="version-validators">{fmt(info.currentValidators)} validators</span>
                </div>
              ))}
            </div>
          </div>
        )}
      </section>

      <!-- DECENTRALIZATION -->
      <section class="section">
        <h2 class="section-title">Decentralization</h2>
        <p class="section-desc">
          How distributed is stake across countries, networks, and individual validators?
        </p>

        <!-- HHI + Gini - prominent -->
        <div class="dec-explainer">
          <div class="dec-explainer-item">
            <div class="dec-explainer-label">
              Market Concentration (HHI)
              <span class="tooltip-wrap">
                <span class="tooltip-icon">?</span>
                <span class="tooltip-box">Herfindahl-Hirschman Index. Used in economics to measure market concentration. Below 1500 is competitive. Above 2500 means a few players dominate. We calculate this for countries and network providers.</span>
              </span>
            </div>
            <p class="dec-explainer-text">
              Imagine all validator stake as a market. HHI tells you how monopolized it is.
              A score near zero means thousands of equal players. A score near 10,000 means one player controls everything.
            </p>
            <div class="dec-explainer-values">
              <div class="dec-val-item">
                <span class="dec-val-num mono {hhiRating(hhi_country).color}">{hhi_country?.toFixed(0) ?? '-'}</span>
                <span class="dec-val-sub">by country</span>
                <span class={`status-badge ${hhiRating(hhi_country).color}`}>{hhiRating(hhi_country).label}</span>
              </div>
              <div class="dec-val-item">
                <span class="dec-val-num mono {hhiRating(hhi_asn).color}">{hhi_asn?.toFixed(0) ?? '-'}</span>
                <span class="dec-val-sub">by network provider</span>
                <span class={`status-badge ${hhiRating(hhi_asn).color}`}>{hhiRating(hhi_asn).label}</span>
              </div>
            </div>
          </div>

          <div class="dec-explainer-item">
            <div class="dec-explainer-label">
              Stake Inequality (Gini)
              <span class="tooltip-wrap">
                <span class="tooltip-icon">?</span>
                <span class="tooltip-box">Gini coefficient measures inequality. 0 means all validators have equal stake. 1 means one validator holds all stake. Used the same way economists measure wealth inequality in a country.</span>
              </span>
            </div>
            <p class="dec-explainer-text">
              Think of it like income inequality, but for stake. A high Gini means a few validators hold most of the network's stake, while hundreds of smaller validators share the rest.
            </p>
            <div class="dec-explainer-values">
              <div class="dec-val-item">
                <span class={`dec-val-num mono ${giniRating(gini).color}`}>{gini?.toFixed(3) ?? '-'}</span>
                <span class="dec-val-sub">across all validators</span>
                <span class={`status-badge ${giniRating(gini).color}`}>{giniRating(gini).label}</span>
              </div>
            </div>
          </div>
        </div>

        <!-- Nakamoto -->
        <div class="subsection-label" style="margin-top: 2rem;">
          Nakamoto Coefficient
          <span class="tooltip-wrap">
            <span class="tooltip-icon">?</span>
            <span class="tooltip-box">The minimum number of independent entities that together control 33%+ of stake. Named after Bitcoin's creator. Higher means more decentralized.</span>
          </span>
        </div>

        <div class="cards-grid cards-4">
          {[
            {
              dim: 'ASN',
              key: 'nakamoto_asn',
              why: 'One network provider (TERASWITCH) hosts enough validators to exceed 33% of stake alone. This is a known concentration risk in Solana infrastructure.'
            },
            {
              dim: 'Country',
              key: 'nakamoto_country',
              why: 'Two countries (US and Germany) together hold over 33% of stake. Geographic concentration creates regulatory and infrastructure risk.'
            },
            {
              dim: 'City',
              key: 'nakamoto_city',
              why: 'Two cities (Frankfurt and Amsterdam) together exceed 33% of stake. Most validators cluster in major European datacenter hubs.'
            },
            {
              dim: 'Validator',
              key: 'nakamoto_validator',
              why: 'It takes 20 independent validators to reach 33% of stake. This is the strongest dimension - no single validator dominates.'
            },
          ].map(({ dim, key, why }) => {
            const val = dec?.[key]?.value;
            const rating = nakRating(dim.toLowerCase(), val);
            const color = nakColor(rating);
            return (
              <div class="card card-nakamoto">
                <div class="card-label">
                  {dim}
                  <span class="tooltip-wrap">
                    <span class="tooltip-icon">?</span>
                    <span class="tooltip-box">{why}</span>
                  </span>
                </div>
                <div class={`card-value-big mono ${color}`}>{val ?? '-'}</div>
                <div class={`status-badge ${color}`}>{rating}</div>
              </div>
            );
          })}
        </div>
      </section>

      <!-- INFRASTRUCTURE -->
      <section class="section">
        <h2 class="section-title">Infrastructure Coverage</h2>
        <p class="section-desc">
          Adoption of advanced networking infrastructure across the validator set.
        </p>

        <div class="cards-grid cards-2">
          <div class="card card-infra">
            <div class="infra-header">
              <div class="infra-name">DoubleZero</div>
              <span class="tooltip-wrap">
                <span class="tooltip-icon">?</span>
                <span class="tooltip-box">A private fiber network that connects Solana validators, bypassing the public internet for faster and more reliable block propagation.</span>
              </span>
            </div>
            <div class="infra-stats">
              <div class="infra-stat">
                <div class="infra-value violet">{fmt(dz?.validators)}</div>
                <div class="infra-label">validators connected</div>
              </div>
              <div class="infra-stat">
                <div class="infra-value">{pct(dz?.validators_percent)}</div>
                <div class="infra-label">of all validators</div>
              </div>
              <div class="infra-stat">
                <div class="infra-value">{pct(dz?.validators_stake_percent)}</div>
                <div class="infra-label">of total stake</div>
              </div>
            </div>
            <div class="infra-detail">
              <span>{fmt(dz?.devices)} devices</span>
              <span class="sep-dot">·</span>
              <span>{fmt(dz?.rpc)} RPC nodes</span>
              <span class="sep-dot">·</span>
              <span class={dz?.network_health?.links_healthy === dz?.network_health?.links_total ? 'good-text' : 'warning-text'}>
                {dz?.network_health?.links_healthy}/{dz?.network_health?.links_total} links healthy
              </span>
            </div>
          </div>

          <div class="card card-infra">
            <div class="infra-header">
              <div class="infra-name">Jito BAM</div>
              <span class="tooltip-wrap">
                <span class="tooltip-icon">?</span>
                <span class="tooltip-box">Block-level Attestation Mechanism by Jito. Coordinates validators for more efficient MEV handling and block building.</span>
              </span>
            </div>
            <div class="infra-stats">
              <div class="infra-stat">
                <div class="infra-value violet">{fmt(bam?.total_connected_validators)}</div>
                <div class="infra-label">validators connected</div>
              </div>
              <div class="infra-stat">
                <div class="infra-value">{pct(bam?.stake_percentage)}</div>
                <div class="infra-label">of total stake</div>
              </div>
              <div class="infra-stat">
                <div class="infra-value">{fmt(bam?.node_count)}</div>
                <div class="infra-label">BAM nodes</div>
              </div>
            </div>
          </div>
        </div>
      </section>

<div class="more-coming-banner">
  <span class="more-coming-icon">+</span>
  More sections in development: Validators Table, Per-validator History, Endpoint Monitor, Geo Discrepancy Analysis, Datacenter Pages, Historical Charts.
</div>

      <!-- GEOGRAPHIC DISTRIBUTION -->
      <section class="section">
        <h2 class="section-title">Geographic Distribution</h2>
        <p class="section-desc">
          Validator count by country. {Object.keys(v?.country_distribution ?? {}).length} countries represented.
        </p>

        <div class="card">
          <div class="geo-chart">
            {topCountries.map(([cc, count]) => {
              const barWidth = Math.round((count / maxCount) * 100);
              const stakePct = v?.stake_by_country?.[cc];
              return (
                <div class="geo-row">
                  <div class="geo-country">
                    <span class="geo-flag">{flag(cc)}</span>
                    <span class="geo-cc">{cc}</span>
                  </div>
                  <div class="geo-bar-wrap">
                    <div class="geo-bar" style={`width: ${barWidth}%`}></div>
                  </div>
                  <div class="geo-count mono">{fmt(count)}</div>
                  {stakePct != null && (
                    <div class="geo-stake">{pct(stakePct)} stake</div>
                  )}
                </div>
              );
            })}
          </div>
        </div>
      </section>

      <!-- ABOUT -->
      <section class="section">
        <h2 class="section-title">About SONDA</h2>

        <div class="cards-grid cards-2">
          <div class="card about-card">
            <h3 class="about-heading">What is SONDA?</h3>
            <p class="about-text">
              SONDA started as private scripts to cross-verify validator geolocation while choosing
              a datacenter for the Solya validator. Existing tools reported conflicting locations,
              so we built a multi-source verification pipeline instead.
            </p>
            <p class="about-text">
              The result is an open-source observatory tracking where validators actually run,
              how infrastructure coverage evolves over time, and what decentralization
              looks like in practice.
            </p>
          </div>

          <div class="card about-card">
            <h3 class="about-heading">What makes it different?</h3>
            <ul class="about-list">
              <li>4-source geo cross-verification per IP (DB-IP, IPInfo, GeoJS, ip-api)</li>
              <li>Discrepancy detection - flags validators where sources disagree</li>
              <li>Full location history since 2021 across 785+ epochs</li>
              <li>DoubleZero and Jito BAM integration with live data</li>
              <li>Three clusters: mainnet, testnet, devnet</li>
              <li>Open source - <a href="https://github.com/SolyaUk/sonda" target="_blank" class="link">github.com/SolyaUk/sonda</a></li>
            </ul>
          </div>
        </div>
      </section>

    </div>
  </main>

  <footer class="site-footer">
    <div class="container">
      <div class="footer-top">
        <div class="footer-brand">
          <span class="footer-logo">SONDA</span>
          <span class="footer-by">by <a href="https://solya.studio" target="_blank" class="link">Solya validator</a></span>
        </div>
        <div class="footer-links">
          <a href="https://github.com/SolyaUk/sonda-network" target="_blank" class="footer-link">GitHub</a>
        </div>
      </div>

      <div class="footer-sources">
        <span class="footer-sources-label">Data sources:</span>
        <span>Solana RPC</span><span class="sep">·</span>
        <span>Jito Kobe</span><span class="sep">·</span>
        <span>SFDP</span><span class="sep">·</span>
        <span>StakeWiz</span><span class="sep">·</span>
        <span>DB-IP</span><span class="sep">·</span>
        <span>IPInfo</span><span class="sep">·</span>
        <span>GeoJS</span><span class="sep">·</span>
        <span>DoubleZero</span><span class="sep">·</span>
        <span>Jito BAM</span><span class="sep">·</span>
        <span>RIPE Stat</span>
      </div>

      <div class="footer-bottom">
        <span>Data updates every ~60 seconds. Last snapshot: <span class="mono">{updatedAt}</span></span>
        <span>MIT License</span>
      </div>

      <!-- Dev status - visible everywhere -->
      <div class="footer-dev-note">
        SONDA is in active development. Features are incomplete and data may not reflect the latest network state.
      </div>
    </div>
  </footer>

  <!-- Prod-only banner - injected via JS only on sonda.network -->
<div id="prod-overlay" style="display:none;">
  <div class="prod-overlay-content">
    <img src="/logo-500.png" alt="SONDA" class="prod-overlay-logo" />
    <h1 class="prod-overlay-title">SONDA</h1>
    <p class="prod-overlay-sub">Solana Observatory for Network Decentralization Analysis</p>
    <div class="prod-overlay-status">
      <span class="dev-badge">IN DEVELOPMENT</span>
    </div>
    <p class="prod-overlay-text">
      We are building a multi-source analytics dashboard for the Solana network.
      Validator geolocation, decentralization metrics, infrastructure coverage,
      and historical data across 785+ epochs.
    </p>
    <div class="prod-overlay-coming">
      <div class="coming-item">Network Health</div>
      <div class="coming-item">Decentralization Metrics (Nakamoto, HHI, Gini)</div>
      <div class="coming-item">DoubleZero and Jito BAM Coverage</div>
      <div class="coming-item">Geographic Distribution</div>
      <div class="coming-item">Validators Table with Search</div>
      <div class="coming-item">Per-validator Location History</div>
      <div class="coming-item">Endpoint Health Monitor</div>
      <div class="coming-item">Geo Discrepancy Analysis</div>
    </div>
    <div class="prod-overlay-links">
      <a href="https://github.com/SolyaUk/sonda-network" target="_blank" rel="noopener" class="prod-overlay-btn">
        View on GitHub
      </a>
      <a href="https://solya.studio" target="_blank" rel="noopener" class="prod-overlay-link">
        by Solya validator
      </a>
    </div>
  </div>
</div>
</BaseLayout>

<style>
/* Dev banner */
.dev-banner {
  background: rgba(59, 130, 246, 0.08);
  border-bottom: 1px solid rgba(59, 130, 246, 0.2);
  font-size: 0.78rem;
  color: var(--text-secondary);
}

.dev-banner-inner {
  max-width: 1280px;
  margin: 0 auto;
  padding: 0.5rem 1.5rem;
  display: flex;
  align-items: center;
  gap: 0.6rem;
  flex-wrap: wrap;
}

.dev-badge {
  font-family: var(--font-mono);
  font-size: 0.65rem;
  font-weight: 600;
  background: var(--accent-blue);
  color: #fff;
  padding: 0.15rem 0.45rem;
  border-radius: 4px;
  letter-spacing: 0.08em;
  flex-shrink: 0;
}

.dev-link {
  color: var(--accent-blue);
  text-decoration: none;
  margin-left: auto;
}

.dev-link:hover { text-decoration: underline; }

/* Prod banner */
#prod-banner {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 200;
}

.prod-banner-inner {
  background: var(--bg-secondary);
  border-top: 1px solid var(--border-accent);
  padding: 0.85rem 1.5rem;
  font-size: 0.82rem;
  color: var(--text-secondary);
  max-width: 1280px;
  margin: 0 auto;
}

.prod-banner-inner a {
  color: var(--accent-blue);
  text-decoration: none;
}

#prod-overlay {
  position: fixed;
  inset: 0;
  z-index: 999;
  background: var(--bg-primary);
  overflow-y: auto;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 2rem 1.5rem;
}

.prod-overlay-content {
  max-width: 560px;
  width: 100%;
  text-align: center;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 1rem;
}

.prod-overlay-logo {
  width: 56px;
  height: 56px;
  border-radius: 12px;
}

.prod-overlay-title {
  font-family: var(--font-display);
  font-size: 2rem;
  font-weight: 700;
  color: var(--text-primary);
  margin: 0;
  letter-spacing: 0.08em;
}

.prod-overlay-sub {
  font-size: 0.82rem;
  color: var(--text-muted);
  text-transform: uppercase;
  letter-spacing: 0.1em;
  margin: 0;
}

.prod-overlay-status {
  margin: 0.25rem 0;
}

.prod-overlay-text {
  font-size: 0.92rem;
  color: var(--text-secondary);
  line-height: 1.7;
  margin: 0;
  max-width: 480px;
}

.prod-overlay-coming {
  display: flex;
  flex-direction: column;
  gap: 0.4rem;
  width: 100%;
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: 12px;
  padding: 1rem 1.25rem;
  text-align: left;
  margin: 0.5rem 0;
}

.coming-item {
  font-size: 0.82rem;
  color: var(--text-secondary);
  padding-left: 1rem;
  position: relative;
}

.coming-item::before {
  content: '+';
  position: absolute;
  left: 0;
  color: var(--accent-blue);
  font-weight: 600;
}

.prod-overlay-links {
  display: flex;
  align-items: center;
  gap: 1.25rem;
  margin-top: 0.5rem;
}

.prod-overlay-btn {
  background: var(--accent-blue);
  color: #fff;
  padding: 0.6rem 1.25rem;
  border-radius: 8px;
  font-size: 0.85rem;
  font-weight: 500;
  text-decoration: none;
  transition: opacity 0.15s ease;
}

.prod-overlay-btn:hover { opacity: 0.85; }

.prod-overlay-link {
  font-size: 0.82rem;
  color: var(--text-muted);
  text-decoration: none;
}

.prod-overlay-link:hover { color: var(--accent-blue); }

/* Layout */
.main-content { padding: 0 0 4rem; }

.container {
  max-width: 1280px;
  margin: 0 auto;
  padding: 0 1.5rem;
}

/* Hero */
.hero {
  padding: 4rem 0 3rem;
  border-bottom: 1px solid var(--border);
  margin-bottom: 3rem;
}

.hero-label {
  font-family: var(--font-mono);
  font-size: 0.7rem;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: var(--accent-blue);
  margin-bottom: 1rem;
}

.hero-title {
  font-family: var(--font-display);
  font-size: clamp(2rem, 5vw, 3.5rem);
  font-weight: 700;
  line-height: 1.15;
  color: var(--text-primary);
  margin: 0 0 1.25rem;
}

.hero-desc {
